# =============================================================================
# Vexi Bot — Environment Variables
# =============================================================================
# On Manus CloudHost, set these in the project's Environment Variables settings.
# =============================================================================

# REQUIRED: Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# REQUIRED: Google Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# REQUIRED: Comma-separated Discord channel IDs where Vexi auto-detects videos
# Right-click a channel in Discord (with Developer Mode on) → Copy Channel ID
VEXI_CHANNELS=1234567890123456789,9876543210123456789

# OPTIONAL: Discord role ID to ping when a video is auto-detected
# Create a "Coaches" role, right-click → Copy Role ID
COACH_ROLE_ID=

# OPTIONAL: Discord guild (server) ID for slash command sync
# Usually auto-detected. Only set if you have command registration issues.
GUILD_ID=

# OPTIONAL: Apify API token for /study fallback when yt-dlp gets rate-limited
# on Instagram/TikTok. Get one at https://console.apify.com/account/integrations
# Without this, /study falls back to telling the user to use lumiscript.manus.space.
APIFY_API_TOKEN=

# OPTIONAL: Override the Apify actor slugs (defaults are sensible)
APIFY_INSTAGRAM_ACTOR=apify/instagram-scraper
APIFY_TIKTOK_ACTOR=clockworks/free-tiktok-scraper

# OPTIONAL: Set to "true" to route the video-bytes download through Apify's
# residential proxy. Use this if you see "Apify scrape OK but CDN download
# blocked: HTTP 403" errors. Costs Apify proxy bandwidth (~$8/GB residential).
# Leave blank/unset to use direct downloads (free, but Instagram CDN may 403).
APIFY_USE_PROXY=

# OPTIONAL: Path to a Netscape-format cookies.txt file for yt-dlp Instagram auth.
# Only needed if you want yt-dlp to authenticate (Apify fallback is usually enough).
INSTAGRAM_COOKIES_FILE=
