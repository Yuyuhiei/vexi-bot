# =============================================================================
# Vexi Bot — Environment Variables
# =============================================================================
# On Manus CloudHost, set these in the project's Environment Variables settings.
# =============================================================================

# REQUIRED: Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# REQUIRED: Google Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# REQUIRED: Comma-separated Discord channel IDs where Vexi auto-detects videos
# Right-click a channel in Discord (with Developer Mode on) → Copy Channel ID
VEXI_CHANNELS=1234567890123456789,9876543210123456789

# OPTIONAL: Discord role ID to ping when a video is auto-detected
# Create a "Coaches" role, right-click → Copy Role ID
COACH_ROLE_ID=

# OPTIONAL: Discord guild (server) ID for slash command sync
# Usually auto-detected. Only set if you have command registration issues.
GUILD_ID=
